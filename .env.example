# Database
DATABASE_URL="postgresql://user:password@localhost:5432/iium_portal?schema=public"

# JWT Configuration
JWT_PRIVATE_KEY_PATH="./config/jwt/private.key"
JWT_PUBLIC_KEY_PATH="./config/jwt/public.key"
JWT_EXPIRATION="8h"

# Email (SMTP) Configuration
SMTP_HOST="smtp.iium.edu.my"
SMTP_PORT=587
SMTP_USER="portal@iium.edu.my"
SMTP_PASS="your-password"
SMTP_FROM="IIUM Software Portal <portal@iium.edu.my>"

# Application URLs
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# Environment
NODE_ENV="development"
API_PORT=3001

# File Upload
MAX_FILE_SIZE=5242880 # 5MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain"

# Rate Limiting
RATE_LIMIT_LOGIN_TTL=900000 # 15 minutes in milliseconds
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_SUBMISSION_TTL=60000 # 1 minute in milliseconds
RATE_LIMIT_SUBMISSION_LIMIT=10
